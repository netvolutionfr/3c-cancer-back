{
  "kind": "collectionType",
  "collectionName": "articles",
  "info": {
    "singularName": "article",
    "pluralName": "articles",
    "displayName": "Article",
    "description": "Les contenus documentaires de l'application"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "titre": {
      "type": "string",
      "required": true
    },
    "resume": {
      "type": "string",
      "maxLength": 255
    },
    "contenu": {
      "type": "richtext",
      "required": true
    },
    "icone": {
      "type": "string",
      "description": "Nom de l'icône (ex: SF Symbols)"
    },
    "ordre": {
      "type": "integer",
      "default": 0
    },
    "ongletParent": {
      "type": "enumeration",
      "enum": [
        "Parcours",
        "Mieux-vivre",
        "Informations"
      ],
      "required": true
    },
    "sectionParente": {
      "type": "string",
      "description": "Ex: 'Les étapes clés', 'Vos Documents expliqués'..."
    },
    "couleurIcone": {
      "type": "string",
      "description": "Couleur de l'icône (ex: purple, blue, red, green)"
    },
    "styleAffichage": {
      "type": "enumeration",
      "enum": [
        "liste",
        "grille"
      ],
      "default": "liste",
      "description": "Style d'affichage : liste classique ou grille de boutons"
    }
  }
}